{
  "buildCommand": "node generate-invoices-manifest.js",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.pdf",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/horizon-portal/members/dashboard",
      "destination": "/horizon-portal/members/dashboard.html"
    },
    {
      "source": "/horizon-portal/members/invoices",
      "destination": "/horizon-portal/members/invoices.html"
    },
    {
      "source": "/horizon-portal/members/dashboard/",
      "destination": "/horizon-portal/members/dashboard.html"
    },
    {
      "source": "/horizon-portal/members/invoices/",
      "destination": "/horizon-portal/members/invoices.html"
    }
  ]
}